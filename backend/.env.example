# Supabase: Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=

# Motor de IA. Por defecto usa OpenAI real (platform.openai.com/api-keys).
# Para usar Google Gemini gratis en su lugar (aistudio.google.com/apikey), descomentá
# las dos líneas de abajo y poné tu key de Gemini en OPENAI_API_KEY.
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_MODEL=gemini-flash-latest

# Tu número de WhatsApp donde llega el informe diario (con o sin +, se normaliza solo). Ej: 5511999999999
ADMIN_WHATSAPP=

# Cuántas sesiones de WhatsApp levantar (una por número). Cada una pide su propio QR al arrancar.
WHATSAPP_SESSIONS=1

PORT=3000
